# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/worklog?schema=public"

# NextAuth 认证配置
NEXTAUTH_SECRET="your-super-secret-key-min-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth (可选)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth (可选)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI API 配置 (至少填一个)
OPENAI_API_KEY="sk-your-openai-api-key"
# ANTHROPIC_API_KEY="your-claude-api-key"

# 应用配置
APP_NAME="AI Worklog Assistant"
APP_URL="http://localhost:3000"

# 邮件服务 (可选，用于通知)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Redis (可选，用于缓存和消息队列)
REDIS_URL="redis://localhost:6379"
