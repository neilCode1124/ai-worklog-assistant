# ============================================
# AI 模型配置
# ============================================

# 模型提供商: openai | anthropic
MODEL_PROVIDER=openai

# 模型名称
# OpenAI 选项: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic 选项: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
MODEL_NAME=gpt-4

# 统一的 LLM API Key（根据 MODEL_PROVIDER 自动使用）
LLM_API_KEY=your-api-key

# ============================================
# 数据库配置
# ============================================

# PostgreSQL 连接字符串
DATABASE_URL="postgresql://user:password@localhost:5432/ai_worklog"

# 或者使用 SQLite（开发环境）
# DATABASE_URL="file:./dev.db"

# ============================================
# 认证配置
# ============================================

NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# 邮件配置（可选）
# ============================================

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email"
SMTP_PASS="your-email-password"

# ============================================
# 应用配置
# ============================================

APP_NAME="AI 工作日志助手"
APP_URL="http://localhost:3000"
